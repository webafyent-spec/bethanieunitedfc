    <!-- Vanilla script: nav, staggered reveals, scroll UI, synthesized SFX (no audio files) -->
    <script is:inline>
      (() => {
        const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;

        /* Mobile nav */
        const t = document.getElementById('nav-toggle');
        const m = document.getElementById('nav-menu');
        if (t && m) {
          t.addEventListener('click', () => {
            const open = m.classList.toggle('open');
            t.setAttribute('aria-expanded', String(open));
          });
          m.querySelectorAll('a').forEach((a) =>
            a.addEventListener('click', () => {
              m.classList.remove('open');
              t.setAttribute('aria-expanded', 'false');
            })
          );
        }

        /* Scroll reveals with stagger */
        const els = document.querySelectorAll('.reveal');
        if (!reduce && 'IntersectionObserver' in window) {
          const io = new IntersectionObserver(
            (entries) => {
              entries
                .filter((e) => e.isIntersecting)
                .forEach((e, i) => {
                  e.target.style.transitionDelay = i * 90 + 'ms';
                  e.target.classList.add('in');
                  io.unobserve(e.target);
                  setTimeout(() => (e.target.style.transitionDelay = ''), 1000 + i * 90);
                });
            },
            { threshold: 0.12 }
          );
          els.forEach((el) => io.observe(el));
        } else {
          els.forEach((el) => el.classList.add('in'));
        }

        /* Scroll-linked UI: progress bar, header shadow, back-to-top */
        const bar = document.getElementById('scroll-progress');
        const header = document.getElementById('site-header');
        const backTop = document.getElementById('back-top');
        let ticking = false;
        const onScroll = () => {
          if (ticking) return;
          ticking = true;
          requestAnimationFrame(() => {
            const y = scrollY;
            const max = document.documentElement.scrollHeight - innerHeight;
            if (bar) bar.style.transform = 'scaleX(' + (max > 0 ? y / max : 0) + ')';
            if (header) header.classList.toggle('scrolled', y > 24);
            if (backTop) backTop.classList.toggle('show', y > 600);
            ticking = false;
          });
        };
        addEventListener('scroll', onScroll, { passive: true });
        onScroll();
        backTop?.addEventListener('click', () =>
          scrollTo({ top: 0, behavior: reduce ? 'auto' : 'smooth' })
        );

        /* SFX — synthesized with WebAudio, opt-in via the speaker toggle */
        const sfxBtn = document.getElementById('sfx-toggle');
        let ctx = null;
        let sfxOn = false;
        const tone = (freq, dur, type, vol, delay) => {
          if (!ctx) return;
          const o = ctx.createOscillator();
          const g = ctx.createGain();
          const t0 = ctx.currentTime + (delay || 0);
          o.type = type || 'triangle';
          o.frequency.value = freq;
          g.gain.setValueAtTime(vol || 0.04, t0);
          g.gain.exponentialRampToValueAtTime(0.0001, t0 + dur);
          o.connect(g).connect(ctx.destination);
          o.start(t0);
          o.stop(t0 + dur + 0.02);
        };
        const clickSfx = () => tone(700, 0.05);
        const whistle = () => {
          tone(2200, 0.12, 'square', 0.03);
          tone(2600, 0.18, 'square', 0.03, 0.15);
        };
        const setIcon = () => {
          sfxBtn.querySelector('.sfx-on').classList.toggle('hidden', !sfxOn);
          sfxBtn.querySelector('.sfx-off').classList.toggle('hidden', sfxOn);
          sfxBtn.setAttribute('aria-pressed', String(sfxOn));
        };
        if (sfxBtn) {
          sfxBtn.addEventListener('click', () => {
            sfxOn = !sfxOn;
            if (sfxOn && !ctx && 'AudioContext' in window) ctx = new AudioContext();
            try {
              localStorage.setItem('bufc-sfx', sfxOn ? '1' : '0');
            } catch {}
            setIcon();
            if (sfxOn) whistle();
          });
          try {
            if (localStorage.getItem('bufc-sfx') === '1') {
              sfxOn = true;
              setIcon();
              /* AudioContext needs a user gesture — create it lazily on first click */
              addEventListener(
                'pointerdown',
                () => {
                  if (sfxOn && !ctx && 'AudioContext' in window) ctx = new AudioContext();
                },
                { once: true }
              );
            }
          } catch {}
          document.addEventListener('click', (e) => {
            if (!sfxOn || !ctx) return;
            const el = e.target.closest('a, button, summary');
            if (el && el.id !== 'sfx-toggle') clickSfx();
          });
        }

        /* Interactive pitch: click/tap to kick the ball; score in a goal for GOAL! */
        const pitch = document.getElementById('pitch');
        if (pitch) {
          const ball = document.getElementById('pitch-ball');
          const goal = document.getElementById('pitch-goal');
          let bx = 300;
          let by = 170;
          let rot = 0;
          let raf = null;
          let lastUser = 0;
          const draw = () =>
            ball.setAttribute('transform', 'translate(' + bx + ' ' + by + ') rotate(' + rot + ')');
          const checkGoal = () => {
            const scored = (bx <= 44 || bx >= 556) && by > 132 && by < 208;
            if (!scored) return;
            goal.classList.remove('show');
            requestAnimationFrame(() => goal.classList.add('show'));
            if (sfxOn && ctx) whistle();
            setTimeout(() => {
              goal.classList.remove('show');
              kick(300, 170, false);
            }, 1200);
          };
          const kick = (tx, ty, user) => {
            tx = Math.max(30, Math.min(570, tx));
            ty = Math.max(26, Math.min(314, ty));
            const sx = bx;
            const sy = by;
            const sr = rot;
            const dx = tx - sx;
            const dy = ty - sy;
            const dist = Math.hypot(dx, dy);
            if (dist < 2) return;
            if (user) {
              lastUser = performance.now();
              if (sfxOn && ctx) tone(160, 0.09, 'sine', 0.07);
            }
            const dur = reduce ? 1 : Math.min(1300, 260 + dist * 2.4);
            const spin = (dist / 63) * 360 * (dx < 0 ? -1 : 1);
            const t0 = performance.now();
            cancelAnimationFrame(raf);
            const step = (now) => {
              const t = Math.min(1, (now - t0) / dur);
              const e = 1 - Math.pow(1 - t, 3);
              bx = sx + dx * e;
              by = sy + dy * e;
              rot = sr + spin * e;
              draw();
              if (t < 1) raf = requestAnimationFrame(step);
              else if (user) checkGoal();
            };
            raf = requestAnimationFrame(step);
          };
          pitch.addEventListener('pointerdown', (ev) => {
            const r = pitch.getBoundingClientRect();
            kick(
              ((ev.clientX - r.left) / r.width) * 600,
              ((ev.clientY - r.top) / r.height) * 340,
              true
            );
          });
          /* Idle: the ball wanders on its own until someone plays with it */
          if (!reduce) {
            setInterval(() => {
              if (performance.now() - lastUser > 8000) {
                kick(80 + Math.random() * 440, 60 + Math.random() * 220, false);
              }
            }, 5000);
          }
        }
      })();
    </script>
  </body>
