---
import '../styles/global.css';

const DOMAIN = 'https://www.bethanieunitedfc.co.za';
const URL = `${DOMAIN}/`;
const NAME = 'Bethanie United Football Club';
const LEGAL_NAME = 'Bethanie United Football Club NPC';
const REG_NO = '2026/444177/08';
const PBO_NO = '930090969';
const PHONE = '+27120018488';
const PHONE_DISPLAY = '012 001 8488';
const ADDRESS = '10230 Otlotleng Section, Bethanie, Brits, North West, 0270';
const LAT = -25.5548;
const LNG = 27.6092;

const TITLE = 'Bethanie United FC | Youth Football Club North West';
const DESCRIPTION =
  'Registered non-profit football club in Bethanie, North West Province. Youth development from U11 to senior, community programmes and sponsorship.';

const teams = [
  'Under 11',
  'Under 13',
  'Under 15',
  'Under 17',
  'Under 19',
  'Senior Team',
];

const missions = [
  {
    title: 'Develop Football Talent',
    text: 'Identify and nurture footballing ability in Bethanie’s young people through structured coaching across six age groups.',
  },
  {
    title: 'Promote Healthy Lifestyles',
    text: 'Use regular training and competition to keep young people active, healthy and away from negative social influences.',
  },
  {
    title: 'Encourage Education',
    text: 'Put schoolwork first, supporting every player to succeed in the classroom as well as on the pitch.',
  },
  {
    title: 'Build Community Pride',
    text: 'Give Bethanie a team to rally behind, strengthening identity and social cohesion across the village.',
  },
  {
    title: 'Foster Leadership',
    text: 'Grow captains, coaches, referees and administrators who lead both in football and in the community.',
  },
];

const impact = [
  {
    title: 'Youth Unemployment',
    text: 'Football keeps young people engaged, builds discipline and opens pathways into coaching, refereeing and sports administration careers.',
  },
  {
    title: 'Sporting Opportunities',
    text: 'Organised sport is scarce in Bethanie. The club brings structured, competitive football to a village that needs it.',
  },
  {
    title: 'Social Challenges',
    text: 'Training, matches and mentorship offer a positive alternative to crime, substance abuse and idleness.',
  },
  {
    title: 'Positive Role Models',
    text: 'Coaches, senior players and directors model the values of passion, unity and excellence for the next generation.',
  },
];

const directors = [
  'Mr. Nkululeko Ambrocious More',
  'Mr. Sheperd Itumeleng More',
  'Ms. Carol Mathule',
];

const faqs = [
  {
    q: 'How do I register my child to play for Bethanie United FC?',
    a: 'Bethanie United FC fields teams in six age groups: Under 11, Under 13, Under 15, Under 17, Under 19 and a Senior team. To register a player, email info@bethanieunitedfc.co.za or phone 012 001 8488 and our administrators will guide you through the digital registration process.',
  },
  {
    q: 'Where is Bethanie United Football Club based?',
    a: 'Bethanie United FC is based in Bethanie village near Brits, in the Madibeng area of South Africa’s North West Province. Our registered office is at 10230 Otlotleng Section, Bethanie, Brits, North West, 0270.',
  },
  {
    q: 'How can my company sponsor Bethanie United FC?',
    a: 'We offer team jersey sponsorship, match-day branding and digital campaign packages, each giving your brand visibility across Bethanie and the wider Madibeng community. Supporting a registered non-profit football club is also a meaningful CSI investment. Email sponsorships@bethanieunitedfc.co.za to receive our sponsorship options.',
  },
  {
    q: 'Is Bethanie United FC a registered non-profit?',
    a: `Yes. Bethanie United Football Club NPC is a registered Non-Profit Company, incorporated with the CIPC on 4 June 2026 under registration number ${REG_NO}. The club is also a registered Public Benefit Organisation (PBO no. ${PBO_NO}), recognised by SARS.`,
  },
  {
    q: 'What age groups can join Bethanie United FC?',
    a: 'The club fields six teams: Under 11, Under 13, Under 15, Under 17, Under 19 and a Senior team. Players progress through a structured pathway from grassroots football to senior competitive level.',
  },
  {
    q: 'What does the club do beyond football?',
    a: 'Beyond match play, Bethanie United FC runs school football programmes, holiday soccer clinics, leadership development, anti-drug awareness campaigns and health and wellness initiatives. It also develops local talent off the pitch through coaching clinics, referee development and football administration training.',
  },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': ['SportsOrganization', 'NonprofitOrganization'],
      '@id': `${DOMAIN}/#club`,
      name: NAME,
      legalName: LEGAL_NAME,
      alternateName: ['Bethanie United FC', 'The Crocodiles of Bethanie', 'BUFC'],
      sport: 'Soccer',
      foundingDate: '2026-06-04',
      identifier: [
        {
          '@type': 'PropertyValue',
          propertyID: 'CIPC Registration',
          value: REG_NO,
        },
        {
          '@type': 'PropertyValue',
          propertyID: 'SARS PBO Number',
          value: PBO_NO,
        },
      ],
      slogan: 'Passion • Unity • Excellence',
      description:
        'Community youth football club in Bethanie village near Brits, North West Province, South Africa. A registered Non-Profit Company developing players from Under 11 to senior level through football, community and talent development programmes.',
      telephone: PHONE,
      email: 'info@bethanieunitedfc.co.za',
      url: URL,
      logo: `${DOMAIN}/icon-512.png`,
      image: `${DOMAIN}/og-image.jpg`,
      address: {
        '@type': 'PostalAddress',
        streetAddress: '10230 Otlotleng Section',
        addressLocality: 'Bethanie',
        addressRegion: 'North West',
        postalCode: '0270',
        addressCountry: 'ZA',
      },
      geo: {
        '@type': 'GeoCoordinates',
        latitude: LAT,
        longitude: LNG,
      },
      areaServed: [
        'Bethanie',
        'Brits',
        'Madibeng Local Municipality',
        'North West Province',
        'South Africa',
      ],
      contactPoint: [
        {
          '@type': 'ContactPoint',
          contactType: 'General Enquiries',
          email: 'info@bethanieunitedfc.co.za',
          telephone: PHONE,
          areaServed: 'ZA',
          availableLanguage: ['English'],
        },
        {
          '@type': 'ContactPoint',
          contactType: 'Sponsorships',
          email: 'sponsorships@bethanieunitedfc.co.za',
          areaServed: 'ZA',
          availableLanguage: ['English'],
        },
      ],
      member: directors.map((name) => ({
        '@type': 'Person',
        name,
        jobTitle: 'Director',
      })),
      knowsAbout: [
        'youth football development',
        'community sport',
        'football coaching',
        'grassroots soccer South Africa',
      ],
    },
    ...teams.map((team) => ({
      '@type': 'SportsTeam',
      '@id': `${DOMAIN}/#team-${team.toLowerCase().replace(/\s+/g, '-')}`,
      name: `Bethanie United FC ${team}`,
      sport: 'Soccer',
      memberOf: { '@id': `${DOMAIN}/#club` },
    })),
    {
      '@type': 'WebSite',
      '@id': `${DOMAIN}/#website`,
      url: URL,
      name: NAME,
      inLanguage: 'en-ZA',
      publisher: { '@id': `${DOMAIN}/#club` },
    },
    {
      '@type': 'FAQPage',
      '@id': `${DOMAIN}/#faq`,
      mainEntity: faqs.map(({ q, a }) => ({
        '@type': 'Question',
        name: q,
        acceptedAnswer: { '@type': 'Answer', text: a },
      })),
    },
  ],
};

/* Decorative gold-dust particles for the hero (deterministic, no runtime cost) */
const particles = Array.from({ length: 14 }, (_, i) => ({
  left: (i * 7.3 + 3) % 100,
  size: 3 + (i % 4) * 2,
  duration: 9 + (i % 5) * 3,
  delay: (i * 1.7) % 9,
}));

const navLinks = [
  { href: '#about', label: 'About' },
  { href: '#programmes', label: 'Programmes' },
  { href: '#sponsorship', label: 'Sponsorship' },
  { href: '#contact', label: 'Contact' },
];
---

<!doctype html>
<html lang="en-ZA">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{TITLE}</title>
    <meta name="description" content={DESCRIPTION} />
    <link rel="canonical" href={URL} />
    <meta
      name="robots"
      content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1"
    />
    <meta name="theme-color" content="#2a1454" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={URL} />
    <meta property="og:site_name" content={NAME} />
    <meta property="og:title" content={TITLE} />
    <meta property="og:description" content={DESCRIPTION} />
    <meta property="og:image" content={`${DOMAIN}/og-image.jpg`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta
      property="og:image:alt"
      content="Bethanie United FC crest on a purple and gold background with the tagline Building Champions On and Off the Field"
    />
    <meta property="og:locale" content="en_ZA" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={URL} />
    <meta name="twitter:title" content={TITLE} />
    <meta name="twitter:description" content={DESCRIPTION} />
    <meta name="twitter:image" content={`${DOMAIN}/og-image.jpg`} />

    <!-- Geo -->
    <meta
      name="geo.placename"
      content="Bethanie, Brits, Madibeng, North West Province, South Africa"
    />
    <meta name="geo.position" content={`${LAT};${LNG}`} />
    <meta name="ICBM" content={`${LAT}, ${LNG}`} />
    <meta name="geo.region" content="ZA-NW" />

    <!-- Dublin Core -->
    <meta name="DC.title" content={TITLE} />
    <meta name="DC.description" content={DESCRIPTION} />
    <meta
      name="DC.subject"
      content="Youth Football, Community Sport, North West Province"
    />
    <meta
      name="DC.coverage"
      content="Bethanie, Brits, Madibeng, North West Province, South Africa"
    />
    <meta name="DC.language" content="en-ZA" />
    <meta name="DC.publisher" content={LEGAL_NAME} />
    <meta name="DC.creator" content={LEGAL_NAME} />
    <meta name="DC.identifier" content={URL} />

    <!-- Icons & manifest -->
    <link rel="icon" href="/icon-192.png" type="image/png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Fonts: Archivo Black (display) + Inter 400/600/700 (body) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Archivo+Black&family=Inter:wght@400;600;700&display=swap"
    />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Archivo+Black&family=Inter:wght@400;600;700&display=swap"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Archivo+Black&family=Inter:wght@400;600;700&display=swap"
      />
    </noscript>

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>

  <body class="bg-purple-950 font-body text-cream">
    <a href="#main" class="skip-link">Skip to main content</a>
    <div id="scroll-progress" aria-hidden="true"></div>

    <!-- ═══ NAV ═══ -->
    <header id="site-header" class="fixed inset-x-0 top-0 z-50 border-b border-gold-500/20 bg-purple-950/90 backdrop-blur">
      <nav aria-label="Main navigation" class="mx-auto flex max-w-6xl items-center justify-between gap-4 px-4 py-3 sm:px-6">
        <a href="#top" class="flex items-center gap-3">
          <img src="/img/bethamie_logo.png" alt="Bethanie United FC crest" width="44" height="44" loading="eager" decoding="async" class="logo-img h-11 w-11" />
          <span class="font-display text-sm leading-tight tracking-wide text-cream sm:text-base">
            BETHANIE UNITED <span class="text-gold-500">FC</span>
          </span>
        </a>

        <div
          id="nav-menu"
          class="absolute left-0 right-0 top-full flex-col gap-1 border-b border-gold-500/20 bg-purple-950 px-4 py-4 md:static md:flex-row md:items-center md:gap-7 md:border-0 md:bg-transparent md:p-0"
        >
          {navLinks.map(({ href, label }) => (
            <a href={href} class="py-2 text-sm font-semibold text-cream transition hover:text-gold-400 md:py-0">
              {label}
            </a>
          ))}
          <a
            href="#sponsorship"
            class="mt-2 inline-block rounded bg-gold-500 px-4 py-2 text-center text-sm font-bold text-purple-950 transition hover:bg-gold-400 md:mt-0"
          >
            Become a Sponsor
          </a>
        </div>

        <div class="flex items-center gap-2">
          <button
            id="sfx-toggle"
            type="button"
            class="rounded-full border border-gold-500/40 p-2 text-gold-400 transition hover:border-gold-400 hover:text-gold-300"
            aria-pressed="false"
            aria-label="Toggle sound effects"
            title="Sound effects"
          >
            <svg class="sfx-off" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M11 5 6 9H2v6h4l5 4V5z" /><line x1="23" y1="9" x2="17" y2="15" /><line x1="17" y1="9" x2="23" y2="15" />
            </svg>
            <svg class="sfx-on hidden" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M11 5 6 9H2v6h4l5 4V5z" /><path d="M15.5 8.5a5 5 0 0 1 0 7" /><path d="M18.5 5.5a9 9 0 0 1 0 13" />
            </svg>
          </button>

          <button
            id="nav-toggle"
            type="button"
            class="rounded border border-gold-500/40 p-2 text-gold-400 md:hidden"
            aria-expanded="false"
            aria-controls="nav-menu"
            aria-label="Toggle navigation menu"
          >
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M4 6h16M4 12h16M4 18h16" />
            </svg>
          </button>
        </div>
      </nav>
    </header>

    <main id="main">
      <!-- ═══ 01 HERO ═══ -->
      <section id="top" class="relative flex min-h-screen items-center overflow-hidden pt-20" aria-label="Introduction">
        <!-- Deep purple base gradient -->
        <div class="absolute inset-0 bg-gradient-to-br from-purple-800 via-purple-950 to-purple-950" aria-hidden="true"></div>
        <!-- Crocodile-scale texture -->
        <div class="croc-scales absolute inset-0 opacity-60" aria-hidden="true"></div>
        <!-- BUFC crest — large watermark right side -->
        <img
          src="/img/hero-crest.png"
          alt=""
          aria-hidden="true"
          width="700"
          height="700"
          fetchpriority="high"
          loading="eager"
          decoding="async"
          class="absolute -right-16 top-1/2 w-[520px] max-w-[55vw] -translate-y-1/2 opacity-25 sm:w-[580px] lg:-right-8 lg:w-[640px] lg:opacity-30 xl:opacity-35 select-none pointer-events-none"
        />
        <!-- Bottom fade so crest blends into sections below -->
        <div class="absolute inset-0 bg-gradient-to-t from-purple-950 via-transparent to-transparent" aria-hidden="true"></div>

        <div class="particles" aria-hidden="true">
          {particles.map(({ left, size, duration, delay }) => (
            <span
              class="particle"
              style={`left:${left}%;width:${size}px;height:${size}px;animation-duration:${duration}s;animation-delay:${delay}s;`}
            ></span>
          ))}
        </div>

        <div class="hero-stagger relative mx-auto w-full max-w-6xl px-4 py-24 sm:px-6">
          <p class="mb-4 text-sm font-bold uppercase tracking-[0.25em] text-gold-400">
            The Crocodiles of Bethanie · Est. 2026
          </p>
          <h1 class="font-display max-w-4xl text-4xl leading-tight text-cream sm:text-5xl lg:text-6xl">
            Bethanie United Football Club —
            <span class="shimmer-text">Youth Football Development</span>
            in North West Province
          </h1>
          <p class="mt-6 max-w-2xl text-lg text-lav sm:text-xl">
            Building Champions On and Off the Field
          </p>
          <div class="mt-10 flex flex-wrap gap-4">
            <a
              href="#contact"
              class="rounded bg-gold-500 px-7 py-3.5 font-bold text-purple-950 transition hover:bg-gold-400"
            >
              Register a Player
            </a>
            <a
              href="#sponsorship"
              class="rounded border-2 border-gold-500 px-7 py-3.5 font-bold text-gold-400 transition hover:bg-gold-500 hover:text-purple-950"
            >
              Become a Sponsor
            </a>
          </div>
        </div>

        <div class="scroll-cue" aria-hidden="true"><span></span></div>
      </section>

      <!-- ═══ MARQUEE TICKER ═══ -->
      <div class="marquee border-y border-gold-500/25 bg-purple-900 py-3.5" aria-hidden="true">
        <div class="marquee-track font-display text-sm tracking-[0.3em] text-gold-500/90">
          {[0, 1].map(() => (
            <span class="pr-8">
              PASSION&ensp;•&ensp;UNITY&ensp;•&ensp;EXCELLENCE&ensp;•&ensp;THE CROCODILES OF BETHANIE&ensp;•&ensp;EST. 2026&ensp;•&ensp;U11 TO SENIOR&ensp;•&ensp;
            </span>
          ))}
        </div>
      </div>

      <!-- ═══ 02 ABOUT ═══ -->
      <section id="about" aria-labelledby="about-h" class="croc-scales border-t border-gold-500/10 bg-purple-900">
        <div class="mx-auto max-w-6xl px-4 py-20 sm:px-6 sm:py-24">
          <div class="reveal mb-12 flex items-end gap-5">
            <span class="section-num" aria-hidden="true">01</span>
            <h2 id="about-h" class="font-display text-2xl text-cream sm:text-4xl">
              A Community Football Club in Bethanie, <span class="text-gold-500">North West</span>
            </h2>
          </div>

          <div class="grid gap-10 lg:grid-cols-5">
            <div class="reveal space-y-5 text-lav lg:col-span-3" data-reveal="left">
              <p>
                Bethanie United Football Club is a community football club rooted in Bethanie
                village near Brits, in the Madibeng area of the North West Province. Founded by
                community leaders who believe sport can change lives, the club was registered with
                the CIPC as a Non-Profit Company on 4 June 2026, under registration number
                {REG_NO}, and is a registered Public Benefit Organisation (PBO no. {PBO_NO}).
              </p>
              <p>
                We exist for four reasons: <strong class="text-cream">youth development</strong>,
                <strong class="text-cream">football excellence</strong>,
                <strong class="text-cream">social cohesion</strong> and
                <strong class="text-cream">community empowerment</strong>. Every training session,
                match and community programme is designed to give the young people of Bethanie a
                structured, positive path — on and off the field.
              </p>
              <div class="pitch-wrap mt-6">
                <svg
                  id="pitch"
                  viewBox="0 0 600 340"
                  role="img"
                  aria-label="Interactive football pitch in club colours — click or tap to kick the ball"
                >
                  <!-- turf + mowing stripes -->
                  <rect x="0" y="0" width="600" height="340" rx="12" fill="#180b36" />
                  <rect x="20" y="16" width="70" height="308" fill="#1d0f3f" />
                  <rect x="160" y="16" width="70" height="308" fill="#1d0f3f" />
                  <rect x="300" y="16" width="70" height="308" fill="#1d0f3f" />
                  <rect x="440" y="16" width="70" height="308" fill="#1d0f3f" />
                  <!-- markings -->
                  <g fill="none" stroke="#d4a73b" stroke-opacity="0.45" stroke-width="2">
                    <rect x="20" y="16" width="560" height="308" />
                    <line x1="300" y1="16" x2="300" y2="324" />
                    <circle cx="300" cy="170" r="40" />
                    <rect x="20" y="96" width="88" height="148" />
                    <rect x="20" y="132" width="34" height="76" />
                    <path d="M108 140 A 40 40 0 0 1 108 200" />
                    <rect x="492" y="96" width="88" height="148" />
                    <rect x="546" y="132" width="34" height="76" />
                    <path d="M492 140 A 40 40 0 0 0 492 200" />
                    <path d="M20 26 A 10 10 0 0 0 30 16" />
                    <path d="M570 16 A 10 10 0 0 0 580 26" />
                    <path d="M580 314 A 10 10 0 0 0 570 324" />
                    <path d="M30 324 A 10 10 0 0 0 20 314" />
                  </g>
                  <circle cx="300" cy="170" r="3.5" fill="#d4a73b" fill-opacity="0.6" />
                  <circle cx="76" cy="170" r="3" fill="#d4a73b" fill-opacity="0.6" />
                  <circle cx="524" cy="170" r="3" fill="#d4a73b" fill-opacity="0.6" />
                  <!-- goals -->
                  <g fill="rgb(212 167 59 / 0.08)" stroke="#e3bc5a" stroke-opacity="0.8" stroke-width="2">
                    <rect x="8" y="140" width="12" height="60" />
                    <rect x="580" y="140" width="12" height="60" />
                  </g>
                  <!-- GOAL! pop -->
                  <text
                    id="pitch-goal"
                    x="300"
                    y="104"
                    text-anchor="middle"
                    font-size="48"
                    font-family="Archivo Black, Arial Black, sans-serif"
                    fill="#e3bc5a"
                    stroke="#14092e"
                    stroke-width="2"
                    paint-order="stroke"
                  >GOAL!</text>
                  <!-- ball (JS moves + spins this group) -->
                  <g id="pitch-ball" transform="translate(300 170)">
                    <circle r="10" fill="#f7f2e7" stroke="#14092e" stroke-width="1.5" />
                    <path d="M0 -4.5 L4.3 -1.4 L2.6 3.6 L-2.6 3.6 L-4.3 -1.4 Z" fill="#2a1454" />
                    <circle cx="0" cy="-8" r="1.6" fill="#2a1454" />
                    <circle cx="7" cy="4" r="1.6" fill="#2a1454" />
                    <circle cx="-7" cy="4" r="1.6" fill="#2a1454" />
                  </g>
                </svg>
                <p class="mt-2 text-xs text-lav/70">
                  ⚽ Click or tap the pitch to kick the ball — see if you can score!
                </p>
              </div>
            </div>

            <!-- Club identity fact card -->
            <aside class="reveal lg:col-span-2" data-reveal="right" aria-label="Club identity facts">
              <div class="rounded-lg border border-gold-500/30 bg-purple-950 p-7">
                <h3 class="font-display mb-6 text-lg text-gold-500">Club Identity</h3>
                <dl class="space-y-4 text-sm">
                  <div>
                    <dt class="font-bold uppercase tracking-wider text-gold-400">Nickname</dt>
                    <dd class="mt-1 text-cream">The Crocodiles of Bethanie</dd>
                  </div>
                  <div>
                    <dt class="font-bold uppercase tracking-wider text-gold-400">Mascot</dt>
                    <dd class="mt-1 text-cream">Crocodile (Kwena)</dd>
                  </div>
                  <div>
                    <dt class="font-bold uppercase tracking-wider text-gold-400">Colours</dt>
                    <dd class="mt-1 text-cream">Purple and Gold</dd>
                  </div>
                  <div>
                    <dt class="font-bold uppercase tracking-wider text-gold-400">Motto</dt>
                    <dd class="mt-1 text-cream">Passion • Unity • Excellence</dd>
                  </div>
                  <div>
                    <dt class="font-bold uppercase tracking-wider text-gold-400">Location</dt>
                    <dd class="mt-1 text-cream">Bethanie, Brits, Madibeng, North West Province</dd>
                  </div>
                  <div>
                    <dt class="font-bold uppercase tracking-wider text-gold-400">Founded</dt>
